# Database connection (async driver not required, psycopg v3 sync is used)
DATABASE_URL=postgresql+psycopg://mealvault:mealvault@localhost:5432/mealvault

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000

# Directory where uploaded dish images are stored
UPLOAD_DIR=./uploads
