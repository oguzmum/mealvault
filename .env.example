# docker-compose overrides (all optional - sensible defaults are built in)
POSTGRES_USER=mealvault
POSTGRES_PASSWORD=mealvault
POSTGRES_DB=mealvault

# Origin(s) the frontend is served from (CORS allow-list for the backend)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Base URL the frontend uses to reach the API (baked into the build)
VITE_API_BASE_URL=http://localhost:8000
